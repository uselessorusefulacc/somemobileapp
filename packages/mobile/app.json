{
  "expo": {
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.agentpilot_a7k2.runable",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiUrl": "https://81ylvadrgdbxmql33216v-preview-4200.runable.site/"
    },
    "ios": {
      "bundleIdentifier": "com.agentpilot_a7k2.runable",
      "supportsTablet": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "name": "MAFA",
    "slug": "agentpilot",
    "version": "1.0.0",
    "scheme": "agentpilot",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AgentPilot to use the camera to scan QR codes from your terminal."
        }
      ]
    ]
  }
}
