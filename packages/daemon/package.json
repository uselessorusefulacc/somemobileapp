{
  "name": "mafa-daemon",
  "version": "1.3.0",
  "description": "mafa — wrap any AI coding agent and monitor it from your phone",
  "type": "module",
  "bin": {
    "mafa": "./dist/daemon.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "bun --watch src/daemon.ts",
    "build": "tsc && node scripts/fix-extensions.js",
    "prepublishOnly": "bun run build",
    "start": "bun src/daemon.ts",
    "typecheck": "tsc --noEmit",
    "detect": "bun src/daemon.ts detect",
    "test": "bun test src/**/*.test.ts"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "bun-types": "latest",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["claude", "codex", "aider", "gemini", "cline", "copilot", "ai-agent", "llm", "monitoring"]
}
