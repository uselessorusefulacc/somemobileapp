{
  "name": "agentpilot-daemon",
  "version": "1.1.0",
  "description": "AgentPilot daemon — wrap any AI coding agent and control it from your phone",
  "type": "module",
  "bin": {
    "agentpilot-daemon": "./src/daemon.ts"
  },
  "scripts": {
    "dev": "bun --watch src/daemon.ts",
    "build": "tsc",
    "start": "bun src/daemon.ts",
    "typecheck": "tsc --noEmit",
    "detect": "bun src/daemon.ts detect"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "bun-types": "latest",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["claude", "codex", "aider", "gemini", "cline", "copilot", "ai-agent", "llm", "monitoring"]
}
